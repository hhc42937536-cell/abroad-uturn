{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "api/download.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "api/view.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "maxDuration": 30 }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/download",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/view",
      "dest": "api/view.py"
    },
    {
      "src": "/api/check_prices",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/refresh_trending",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/warm_exchange",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/warm_flights",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/visa_reminder",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/check_policies",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/check_feedback",
      "dest": "api/webhook.py"
    }
  ],
  "crons": [
    {
      "path": "/api/check_prices",
      "schedule": "0 8 * * 1,3,5"
    },
    {
      "path": "/api/refresh_trending",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/warm_exchange",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/warm_flights",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/check_policies",
      "schedule": "30 3 * * 1"
    },
    {
      "path": "/api/visa_reminder",
      "schedule": "30 4 * * 1"
    },
    {
      "path": "/api/check_feedback",
      "schedule": "0 1 * * *"
    }
  ]
}
