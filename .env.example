PORT=3000
NODE_ENV=development

# Leave DATABASE_URL empty for memory-store local development.
# Production example: postgresql://user:password@host:5432/travel_bot?sslmode=require
DATABASE_URL=
REDIS_URL=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
RICH_MENU_IMAGE_PATH=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Keep false to save cost. Set true to let the LLM fix user inputs such as dates.
LLM_INPUT_NORMALIZATION=false
# Fare refresh updates cached prices only. It does not send LINE push messages.
ENABLE_FARE_REFRESH=true
FARE_REFRESH_ORIGINS=TPE
FARE_UPDATE_CRON=0 9 * * 1,3,5
FARE_UPDATE_TIMEZONE=Asia/Taipei
# Optional: send one-to-one push only for tracked route drops greater than 5%.
ENABLE_PRICE_PUSH=false
PRICE_CHECK_CRON=15 9 * * 1,3,5

EXCHANGERATE_API_KEY=
TRAVELPAYOUTS_TOKEN=
TP_MARKER=
GOOGLE_MAPS_API_KEY=
SKYSCANNER_API_KEY=
APIFY_TOKEN=

APP_BASE_URL=https://your-service.example.com
